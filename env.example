# ═══════════════════════════════════════════════
# Front-Tech — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!
# ═══════════════════════════════════════════════

# ── Stripe ──────────────────────────────────────
# Get from: stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Get from: stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── Email (Gmail recommended) ────────────────────
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to myaccount.google.com → Security → App passwords
# Step 3: Create app password called "Front-Tech" → copy 16-char code
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password_here
FROM_EMAIL=your@gmail.com

# ── App ──────────────────────────────────────────
# Your Streamlit Cloud URL
DASHBOARD_URL=https://your-app.streamlit.app

# Port for the webhook server (Railway sets this automatically)
PORT=5000
